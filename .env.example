# Copy this file to .env.local and fill in real values.

# Optional — enables the contact form to send real emails via Resend
# (https://resend.com). Without this set, submissions are logged
# server-side only and the form still returns a success response.
RESEND_API_KEY=

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=asma.babazadehkahrizi@gmail.com

# Public site URL, used for metadata, OpenGraph and sitemap generation
NEXT_PUBLIC_SITE_URL=https://asmababazadehkahrizi.com
